# Copy this file to .env and replace placeholders with your values.
# Do not commit .env (it is in .gitignore).

# Database: PostgreSQL (default) or SqlServer
Database__Provider=PostgreSQL

# PostgreSQL (when Provider=PostgreSQL)
ConnectionStrings__DefaultConnection=Host=localhost;Database=notesdb;Username=YOUR_USER;Password=YOUR_PASSWORD;Port=5432

# SQL Server (when Provider=SqlServer) - use instead of above
# ConnectionStrings__DefaultConnection=Server=localhost;Database=NotesDb;User Id=YOUR_USER;Password=YOUR_PASSWORD;TrustServerCertificate=True;

# JWT - use a long random string in production (min 32 characters)
Jwt__Key=YourSecretKeyForJwtSigningAtLeast32CharactersLong!
Jwt__Issuer=NotesApi
Jwt__Audience=NotesApp
